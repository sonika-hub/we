<html lang="en">
<head>
    <%- include("partials/header") %>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/ScrollTrigger.min.js"></script>

    <style>
        /* --- MOBILE RESPONSIVE FIXES --- */
        @media (max-width: 768px) {
            .gallery-hero {
                padding: 80px 5% 20px !important;
            }

            /* Force the grid into a single column on mobile */
            .photo-dump-grid {
                display: flex !important;
                flex-direction: column !important;
                gap: 15px !important;
            }

            /* Reset all spanning classes so images take full width */
            .dump-item.large, 
            .dump-item.tall, 
            .dump-item.wide,
            .dump-item {
                grid-column: span 1 !important;
                grid-row: span 1 !important;
                height: 350px !important; /* Fixed height for consistent mobile scrolling */
                width: 100% !important;
            }

            h1 {
                letter-spacing: 8px !important;
                font-size: 2.5rem !important;
            }
        }

        /* Essential styles to ensure images look good in the grid */
        .dump-item {
            position: relative;
            overflow: hidden;
            border-radius: 12px;
            background: #111;
        }

        .dump-item img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform 0.8s ease;
        }

        .dump-item:hover img {
            transform: scale(1.05);
        }
    </style>
</head>
<body class="gallery-page">
<%- include("partials/navbar") %>

<section class="gallery-hero" style="padding: 120px 5% 40px; text-align: center;">
    <h1 style="font-family: 'Syne'; font-size: clamp(2rem, 8vw, 5rem); opacity: 0.2; letter-spacing: 15px;">MOMENTS</h1>
</section>

<section class="gallery-section" style="padding: 0 20px 100px;">
    <div class="photo-dump-grid">
        <div class="dump-item large"><img src="/images/couple1.jpg" alt="Gallery"></div>
        <div class="dump-item tall"><img src="/images/couple2.jpg" alt="Gallery"></div>
        <div class="dump-item"><img src="/images/couple3.jpg" alt="Gallery"></div>
        <div class="dump-item wide"><img src="/images/couple4.jpg" alt="Gallery"></div>
        <div class="dump-item"><img src="/images/couple5.jpg" alt="Gallery"></div>
        <div class="dump-item tall"><img src="/images/couple6.jpg" alt="Gallery"></div>
        <div class="dump-item large"><img src="/images/couple7.jpg" alt="Gallery"></div>
        <div class="dump-item"><img src="/images/couple8.jpg" alt="Gallery"></div>
        <div class="dump-item wide"><img src="/images/couple9.jpg" alt="Gallery"></div>
    </div>
</section>

<%- include("partials/footer") %>

<script>
    gsap.registerPlugin(ScrollTrigger);

    // Subtle reveal animation as you scroll
    // Staggered reveal works better for grids
    gsap.from(".dump-item", {
        scrollTrigger: {
            trigger: ".photo-dump-grid",
            start: "top 85%",
            toggleActions: "play none none reverse"
        },
        y: 40,
        opacity: 0,
        duration: 1,
        stagger: 0.1, // Images will pop in one after another
        ease: "power2.out"
    });
</script>
</body>
</html>