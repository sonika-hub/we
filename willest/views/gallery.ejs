<html lang="en">
<head>
    <%- include("partials/header") %>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/ScrollTrigger.min.js"></script>
</head>
<body class="gallery-page">
<%- include("partials/navbar") %>

<section class="gallery-hero" style="padding: 120px 5% 40px; text-align: center;">
    <h1 style="font-family: 'Syne'; font-size: clamp(2rem, 8vw, 5rem); opacity: 0.2; letter-spacing: 15px;">MOMENTS</h1>
</section>

<section class="gallery-section" style="padding: 0 20px 100px;">
    <div class="photo-dump-grid">
        <div class="dump-item large"><img src="/images/couple1.jpg" alt="Gallery"></div>
        <div class="dump-item tall"><img src="/images/couple2.jpg" alt="Gallery"></div>
        <div class="dump-item"><img src="/images/couple3.jpg" alt="Gallery"></div>
        <div class="dump-item wide"><img src="/images/couple4.jpg" alt="Gallery"></div>
        <div class="dump-item"><img src="/images/couple5.jpg" alt="Gallery"></div>
        <div class="dump-item tall"><img src="/images/couple6.jpg" alt="Gallery"></div>
        <div class="dump-item large"><img src="/images/couple7.jpg" alt="Gallery"></div>
        <div class="dump-item"><img src="/images/couple8.jpg" alt="Gallery"></div>
        <div class="dump-item wide"><img src="/images/couple9.jpg" alt="Gallery"></div>
    </div>
</section>

<%- include("partials/footer") %>

<script>
    // Subtle reveal animation as you scroll
    gsap.utils.toArray(".dump-item").forEach((item) => {
        gsap.from(item, {
            scrollTrigger: {
                trigger: item,
                start: "top 90%",
                toggleActions: "play none none reverse"
            },
            y: 30,
            opacity: 0,
            duration: 1,
            ease: "power2.out"
        });
    });
</script>
</body>
</html>